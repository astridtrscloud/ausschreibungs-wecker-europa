# LLM-Konfiguration (OpenAI-kompatibel)
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_API_KEY=sk-dein-key-hier
LLM_MODEL=kimi-latest

# SMTP fuer E-Mail-Benachrichtigungen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dein-email@gmail.com
SMTP_PASS=dein-app-password
MAIL_TO=empfaenger@firma.de

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Dashboard Auth
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# Scheduler (Minuten)
SCRAPE_INTERVAL_MINUTES=30

# Database (SQLite default, PostgreSQL-ready)
DATABASE_URL=sqlite:///./data/ausschreibungen.db

# TED-Laenderfilter (leer = alle EU-Laender)
TED_COUNTRIES=

# simap.ch aktivieren
SIMAP_ENABLED=true
